{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx"
  },
  "include": [
    "packages/**/*.ts",
    "apps/desktop/electron/**/*.ts",
    "apps/desktop/src/**/*.ts",
    "apps/desktop/src/**/*.tsx",
    "apps/web/src/**/*.ts",
    "apps/web/src/**/*.tsx",
    "apps/web/tests/**/*.mjs",
    "types/**/*.d.ts"
  ]
}

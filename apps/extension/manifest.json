{
  "manifest_version": 3,
  "name": "Orislop Clean Feeds",
  "version": "0.4.0",
  "description": "Use required local Ollama plus Orislop spatial and temporal detectors to hide slop and synthetic media.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://m.youtube.com/*",
    "https://www.instagram.com/*",
    "https://www.tiktok.com/*",
    "http://127.0.0.1:11434/*",
    "http://localhost:11434/*",
    "http://127.0.0.1:4317/*",
    "http://localhost:4317/*"
  ],
  "icons": {
    "16": "icons/icon16.svg",
    "32": "icons/icon32.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg",
    "256": "icons/icon256.svg"
  },
  "action": {
    "default_title": "Orislop",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.svg",
      "32": "icons/icon32.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg",
      "256": "icons/icon256.svg"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://m.youtube.com/*",
        "https://www.instagram.com/*",
        "https://www.tiktok.com/*"
      ],
      "js": ["aiClassifierModel.generated.js", "classifier.js", "controlCore.js", "contentScript.js"],
      "css": ["contentStyles.css"],
      "run_at": "document_idle"
    }
  ]
}

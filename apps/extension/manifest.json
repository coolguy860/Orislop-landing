{
  "manifest_version": 3,
  "name": "Orislop Clean YouTube",
  "version": "0.2.0",
  "description": "Hide low-value YouTube videos locally with Orislop's lightweight browser scoring.",
  "permissions": ["storage"],
  "host_permissions": ["https://www.youtube.com/*", "https://m.youtube.com/*"],
  "icons": {
    "16": "icons/icon16.svg",
    "32": "icons/icon32.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg",
    "256": "icons/icon256.svg"
  },
  "action": {
    "default_title": "Orislop",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.svg",
      "32": "icons/icon32.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg",
      "256": "icons/icon256.svg"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*", "https://m.youtube.com/*"],
      "js": ["aiClassifierModel.generated.js", "controlCore.js", "contentScript.js"],
      "css": ["contentStyles.css"],
      "run_at": "document_idle"
    }
  ]
}
